/* 机械迷城 首页样式 */
.container {
  width: 100vw;
  height: 100vh;
  background-color: #3a3228;
  position: relative;
  overflow: hidden;
}

/* 入场动画 */
@keyframes slideUp {
  from {
    transform: translateY(100rpx);
    opacity: 0;
  }
  to {
    transform: translateY(0);
    opacity: 1;
  }
}

@keyframes fadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

/* 开始屏幕 */
.start-screen {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #f0e6d6;
}

.title {
  font-size: 64rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
  color: #b89a6b;
  animation: slideUp 0.6s ease-out forwards;
}

.subtitle {
  font-size: 28rpx;
  margin-bottom: 100rpx;
  color: #8b6e4b;
  animation: slideUp 0.6s ease-out 0.1s forwards;
  opacity: 0;
}

.start-btn {
  width: 300rpx;
  height: 80rpx;
  line-height: 80rpx;
  background-color: #8b6e4b;
  color: #fff;
  border-radius: 10rpx;
  border: none;
  font-size: 32rpx;
  animation: slideUp 0.6s ease-out 0.2s forwards;
  opacity: 0;
  transition: transform 0.1s ease, background-color 0.2s ease;
}

.start-btn:active {
  transform: scale(0.95);
  background-color: #7a5e3b;
}

.hint {
  margin-top: 30rpx;
  font-size: 24rpx;
  color: #6a8876;
}

/* 游戏画布 */
.game-canvas {
  width: 100%;
  height: calc(100vh - 120rpx);
}

/* 底部UI */
.bottom-ui {
  width: 100%;
  height: 120rpx;
  background-color: rgba(45, 38, 30, 0.9);
  display: flex;
  align-items: center;
  padding: 0 20rpx;
  box-sizing: border-box;
}

.inventory {
  flex: 1;
  display: flex;
  gap: 10rpx;
}

.item {
  width: 80rpx;
  height: 80rpx;
  background-color: #8b6e4b;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid transparent;
  box-sizing: border-box;
}

.item.selected {
  border-color: #ffcc66;
  transform: scale(1.15);
  box-shadow: 0 0 20rpx rgba(255, 204, 102, 0.7);
}

.item:active {
  transform: scale(0.95);
}

.item-img {
  width: 60rpx;
  height: 60rpx;
}

.hint-btn, .save-btn {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background-color: #8b6e4b;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  padding: 0;
  margin-left: 20rpx;
  border: none;
  transition: transform 0.1s ease;
}

.hint-btn:active, .save-btn:active {
  transform: scale(0.95);
}

/* 存档选择界面 */
.save-select-screen {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #f0e6d6;
  animation: fadeIn 0.3s ease forwards;
}

.save-title {
  font-size: 48rpx;
  font-weight: bold;
  margin-bottom: 60rpx;
  color: #b89a6b;
}

.save-list {
  width: 80%;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 40rpx;
}

.save-item {
  width: 100%;
  padding: 30rpx;
  background-color: rgba(139, 110, 75, 0.2);
  border-radius: 12rpx;
  border: 2rpx solid #8b6e4b;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  transition: all 0.2s ease;
}

.save-item:active {
  transform: scale(0.98);
  background-color: rgba(139, 110, 75, 0.4);
}

.save-slot {
  font-size: 32rpx;
  font-weight: bold;
  color: #f0e6d6;
}

.save-time {
  font-size: 24rpx;
  color: #b89a6b;
}

.save-status {
  font-size: 22rpx;
  color: #6a8876;
  align-self: flex-end;
}

.save-status.new {
  color: #a84a4a;
}

.back-btn {
  width: 200rpx;
  height: 70rpx;
  line-height: 70rpx;
  background-color: #6a5a44;
  color: #fff;
  border-radius: 8rpx;
  border: none;
  font-size: 28rpx;
}

.settings-btn {
  width: 200rpx;
  height: 70rpx;
  line-height: 70rpx;
  background-color: #6a5a44;
  color: #fff;
  border-radius: 8rpx;
  border: none;
  font-size: 28rpx;
  margin-top: 20rpx;
}

/* 设置弹窗 */
.settings-modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  background-color: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
  animation: fadeIn 0.3s ease forwards;
}

.settings-content {
  width: 80vw;
  background-color: #5a4a3a;
  padding: 40rpx;
  border-radius: 16rpx;
  border: 4rpx solid #8b6e4b;
}

.settings-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #f0e6d6;
  text-align: center;
  margin-bottom: 40rpx;
}

.settings-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 30rpx;
}

.settings-label {
  font-size: 28rpx;
  color: #f0e6d6;
}

/* 滑块样式 */
.slider {
  width: 300rpx;
  height: 20rpx;
  position: relative;
}

.slider-track {
  width: 100%;
  height: 6rpx;
  background-color: #3a3228;
  border-radius: 3rpx;
  position: absolute;
  top: 7rpx;
}

.slider-fill {
  height: 6rpx;
  background-color: #b89a6b;
  border-radius: 3rpx;
}

.slider-thumb {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background-color: #b89a6b;
  position: absolute;
  top: -2rpx;
}

/* 开关样式 */
.toggle {
  width: 80rpx;
  height: 40rpx;
  border-radius: 20rpx;
  background-color: #3a3228;
  position: relative;
  transition: background-color 0.2s ease;
}

.toggle.on {
  background-color: #6a8876;
}

.toggle-thumb {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  background-color: #fff;
  position: absolute;
  top: 4rpx;
  left: 4rpx;
  transition: left 0.2s ease;
}

.toggle.on .toggle-thumb {
  left: 44rpx;
}

.settings-close {
  width: 100%;
  height: 70rpx;
  line-height: 70rpx;
  background-color: #8b6e4b;
  color: #fff;
  border-radius: 8rpx;
  border: none;
  font-size: 28rpx;
  margin-top: 20rpx;
}

/* 提示弹窗 */
.hint-modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  background-color: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.hint-content {
  width: 80vw;
  background-color: #5a4a3a;
  padding: 40rpx;
  border-radius: 16rpx;
  border: 4rpx solid #8b6e4b;
}

.hint-text {
  color: #f0e6d6;
  font-size: 30rpx;
  line-height: 1.6;
}
